{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openrdw.local/schemas/episode.schema.json",
  "title": "OpenRDW Episode",
  "type": "object",
  "required": [
    "schema_version",
    "episode_id",
    "source",
    "users",
    "frames"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "episode_id": {
      "type": "string",
      "minLength": 1
    },
    "source": {
      "type": "string",
      "enum": [
        "unity",
        "python",
        "external"
      ]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "environment": {
      "type": "object",
      "additionalProperties": true
    },
    "users": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "user_id"
        ],
        "properties": {
          "user_id": {
            "type": "string",
            "minLength": 1
          },
          "role": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    },
    "frames": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "t",
          "users"
        ],
        "properties": {
          "t": {
            "type": "number",
            "minimum": 0
          },
          "users": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "user_id",
                "position",
                "forward"
              ],
              "properties": {
                "user_id": {
                  "type": "string"
                },
                "position": {
                  "$ref": "#/$defs/vector3"
                },
                "forward": {
                  "$ref": "#/$defs/vector3"
                },
                "velocity": {
                  "$ref": "#/$defs/vector3"
                }
              },
              "additionalProperties": true
            }
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true,
  "$defs": {
    "vector3": {
      "type": "object",
      "required": [
        "x",
        "y",
        "z"
      ],
      "properties": {
        "x": {
          "type": "number"
        },
        "y": {
          "type": "number"
        },
        "z": {
          "type": "number"
        }
      },
      "additionalProperties": false
    }
  }
}

